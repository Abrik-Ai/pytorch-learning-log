# PATTERN: Manual gradient descent from scratch (no nn.Module, no optimizer object)
# Learned: tensors, requires_grad, forward pass, loss (MSE), .backward(),
# gradients (.grad), manual weight update, torch.no_grad(), learning rate
# Goal: learn y = 2x purely by trial-and-error, using gradient descent

import torch

# Training data: y = 2x
x = torch.tensor([1.0, 2.0, 3.0, 4.0])
y = torch.tensor([2.0, 4.0, 6.0, 8.0])

# The one weight we're trying to learn, starting from a random guess (0.0)
w = torch.tensor([0.0], requires_grad=True)

# Training loop
for epoch in range(20):
    y_pred = w * x                     # forward pass: make a prediction
    loss = ((y_pred - y) ** 2).mean()  # measure how wrong the prediction is (MSE)

    loss.backward()                    # backpropagation: calculate the gradient automatically

    with torch.no_grad():              # pause tracking for the manual update step
        w -= 0.1 * w.grad              # gradient descent: move w in the direction that reduces loss

    w.grad.zero_()                     # reset the gradient before the next epoch

    print(f"epoch {epoch}: w = {w.item():.3f}, loss = {loss.item():.3f}")
